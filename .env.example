# App
FLASK_ENV=development
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-too
DATABASE_URL=sqlite:///instance/database.db

# Integrations
OPENAI_API_KEY=
YANDEX_TOKEN=

# WebDAV
WEBDAV_URL=https://webdav.cloud.mail.ru
WEBDAV_LOGIN=
WEBDAV_PASSWORD=
WEBDAV_ROOT_PATH=/

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

# Deployment / webhook
GITHUB_WEBHOOK_SECRET=
REPO_PATH=/path/to/teacher_tool
WSGI_FILE_PATH=/var/www/your_wsgi_file.py
RELOAD_CMD=

# Optional: init_db.py bootstrap values
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_EMAIL=admin@example.com
INIT_ADMIN_PASSWORD=

# Optional: scripts/set_admin_password.py
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
